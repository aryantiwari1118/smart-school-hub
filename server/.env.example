# MongoDB Configuration
# For MongoDB Atlas (cloud): mongodb+srv://username:password@cluster.mongodb.net/smart-school-hub
# For Local MongoDB: mongodb://localhost:27017/smart-school-hub
MONGODB_URI=mongodb://localhost:27017/smart-school-hub

# Server Configuration
PORT=5000
SECRET_KEY=your-secret-key-change-in-production-for-security

# Note: 
# - If MONGODB_URI is not set, the app runs in test mode with hardcoded credentials
# - Test credentials will always be available for development
# - In production, always set MONGODB_URI to a secure MongoDB instance
